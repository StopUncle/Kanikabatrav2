generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String               @id @default(cuid())
  email                     String               @unique
  password                  String
  name                      String?
  displayName               String?
  avatarUrl                 String?
  gender                    Gender?
  // Incremented on every successful password reset. Reset tokens embed this
  // value at issue time; if the two don't match, the token is rejected.
  // This is what makes reset tokens single-use without needing a separate
  // blacklist table.
  tokenVersion              Int                  @default(0)
  // When the user dismissed the Inner Circle onboarding tour. Null means
  // they haven't seen it yet — the feed renders the welcome modal on
  // their first visit after activation.
  onboardingSeenAt          DateTime?
  emailPreferences          Json?
  role                      UserRole             @default(MEMBER)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  sessions                  CoachingSession[]
  purchases                 Purchase[]
  forumPosts                ForumPost[]
  forumReplies              ForumReply[]
  postLikes                 PostLike[]
  replyLikes                ReplyLike[]
  chatMessages              ChatMessage[]
  chatMembers               ChatMember[]
  subscriptions             Subscription[]
  enrollments               CourseEnrollment[]
  activities                ActivityLog[]
  achievements              UserAchievement[]
  quizResults               QuizResult[]
  communityMembership       CommunityMembership?
  feedPosts                 FeedPost[]
  feedComments              FeedComment[]
  feedPostLikes             FeedPostLike[]
  commentLikes              CommentLike[]
  points                    Int                  @default(0)
  level                     Int                  @default(1)
  isBanned                  Boolean              @default(false)
  banReason                 String?
  // Messaging restriction — softer than a ban. User can still read
  // and browse, but cannot post comments. Toggled per-user by admin.
  messagingRestricted       Boolean              @default(false)
  messagingRestrictedAt     DateTime?
  messagingRestrictedReason String?
  reportsFiled              CommentReport[]      @relation("ReportsFiled")
  reportsResolved           CommentReport[]      @relation("ReportsResolved")
  simulatorProgress         SimulatorProgress[]
  // Simulator daily-streak. simulatorStreakCurrent ticks up by 1 the first
  // time the user takes a simulator action on a calendar day; resets to 0
  // if a full day passes without one. simulatorStreakLongest is monotonically
  // increasing — read-only "all-time best" displayed on the catalog header.
  // simulatorLastSession is the timestamp of the last action; the day-rollover
  // check compares its date to today's date in UTC.
  simulatorStreakCurrent    Int                  @default(0)
  simulatorStreakLongest    Int                  @default(0)
  simulatorLastSession      DateTime?
  simulatorBadges           SimulatorBadge[]
  isBot                     Boolean              @default(false)
  botActive                 Boolean              @default(true)
  botActions                BotAction[]
  // Training bots fill the Tells leaderboard / league brackets so the
  // social pressure layer reads as alive at low real-member counts.
  // Distinct from `isBot` (community-engagement bots that comment +
  // post). Training bots never post, never get push, never have a
  // CommunityMembership, never count in member-facing metrics.
  isTrainingBot             Boolean              @default(false)
  // { archetype, baseSkill, activityProb, axisStrengths, originDay }.
  // Drives the daily-tick cron that advances each bot's TellResponse +
  // streak + Elo without any LLM calls. Pure deterministic math.
  botProfile                Json?
  memberQuestions           MemberQuestion[]     @relation("MemberQuestions")
  questionUpvotes           QuestionUpvote[]     @relation("QuestionUpvotes")
  // PWA push subscriptions (one per device). The browser issues a
  // unique endpoint per (origin, device, browser-instance), so a
  // user with phone + laptop has two rows. Pruned automatically
  // when web-push reports a 404/410 from the push service.
  pushSubscriptions         PushSubscription[]
  // Per-category push notification opt-ins. JSON for flexibility:
  // { questionAnswered: true, voiceNote: true, forumReply: false }.
  // Null = all defaults (treated as opt-in for the categories
  // shipped today). Member prefs UI in /consilium/profile lets the
  // member toggle each category.
  pushPreferences           Json?
  // Tells, the daily Train-Your-Instincts product. Three tables:
  // TellResponse (one row per answer), InstinctScore (six-axis Elo),
  // TellStreak (current/longest day count + weekly freeze).
  tellResponses             TellResponse[]
  instinctScore             InstinctScore?
  tellStreak                TellStreak?
  receipts                  Receipt[]
  // Public-profile slug for /u/[handle]. Optional (member opts in by
  // claiming a handle). Lowercase a-z, 0-9, hyphens. 3-30 chars.
  // Unique only when set; null users do not collide.
  handle                    String?              @unique
  // Whether the user has chosen to make their hex public on /u/[handle].
  // Default false: claiming a handle does not auto-publish the hex.
  profilePublic             Boolean              @default(false)
  // Acquisition attribution — captured from URL params + headers on
  // the visit that ended in registration. Joinable against revenue
  // (Purchase), retention (CommunityMembership), and quiz outcomes
  // for source-level ROI. All nullable — pre-attribution users +
  // direct/organic traffic stay null.
  utmSource                 String?
  utmMedium                 String?
  utmCampaign               String?
  utmContent                String?
  utmTerm                   String?
  // Click IDs from ad platforms — survive even when UTM params are
  // stripped by the platform (Meta sometimes does this on IG ads).
  gclid                     String?
  fbclid                    String?
  ttclid                    String?
  // Last URL the visitor came from (document.referrer) and first
  // path they hit on this site.
  referrer                  String?
  landingPage               String?
  // Device + locale — useful for region-specific funnel tuning.
  userAgent                 String?
  ipCountry                 String?
  language                  String?
  timezone                  String?

  @@index([email])
  @@index([utmSource])
  @@index([utmCampaign])
  @@index([isBot])
  @@index([isTrainingBot])
}

enum UserRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum MembershipStatus {
  PENDING
  APPROVED
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum FeedPostType {
  VOICE_NOTE
  ANNOUNCEMENT
  DISCUSSION_PROMPT
  AUTOMATED
  VIDEO
}

enum CommentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  HIDDEN
}

model Purchase {
  id              String            @id @default(cuid())
  userId          String?
  type            ProductType
  productVariant  String?
  customerEmail   String
  customerName    String
  amount          Float
  status          PurchaseStatus    @default(PENDING)
  paypalOrderId   String?           @unique
  paypalCaptureId String?
  downloadToken   String?           @unique
  downloadCount   Int               @default(0)
  maxDownloads    Int               @default(10)
  lastDownloadAt  DateTime?
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        CoachingSession[]
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paypalOrderId])
  @@index([customerEmail])
  @@index([downloadToken])
}

model CoachingSession {
  id                String           @id @default(cuid())
  purchaseId        String
  userId            String?
  packageName       String
  sessionCount      Int              @default(1)
  scheduledAt       DateTime?
  duration          Int?
  status            SessionStatus    @default(PENDING_SCHEDULING)
  meetingUrl        String?
  notes             String? // Coach notes
  userNotes         String?          @db.Text // User's personal notes
  questionnaireData Json? // Stores questionnaire responses as DB backup
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  purchase          Purchase         @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback          SessionFeedback?

  @@index([userId])
  @@index([purchaseId])
  @@index([scheduledAt])
}

// Session Feedback - User feedback after completing a coaching session
model SessionFeedback {
  id        String          @id @default(cuid())
  sessionId String          @unique
  rating    Int // 1-5 stars
  feedback  String?         @db.Text // General feedback
  goals     String?         @db.Text // What user wanted to achieve
  outcomes  String?         @db.Text // What was achieved
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   CoachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum ProductType {
  BOOK
  COURSE
  COACHING
  QUIZ
  DONATION
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SessionType {
  INDIVIDUAL
  GROUP
  VIP
}

enum SessionStatus {
  PENDING_SCHEDULING
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Blog System - Content stored in MDX files, DB tracks metadata
model Post {
  id        String   @id @default(cuid())
  slug      String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([slug])
}

// Quiz System - The Dark Mirror Assessment (Cluster B Personality Types)
model QuizResult {
  id                       String    @id @default(cuid())
  userId                   String?
  email                    String?
  primaryType              String // "psychopathic" | "sociopathic" | "narcissistic" | "borderline" | "histrionic"
  secondaryType            String?
  scores                   Json // { psychopathic: 25, sociopathic: 15, narcissistic: 30, borderline: 20, histrionic: 10 }
  answers                  Json // All question answers for analytics
  paid                     Boolean   @default(false)
  paypalOrderId            String?   @unique
  emailSent                Boolean   @default(false)
  shared                   Boolean   @default(false)
  // Consilium credit. On QUIZ purchase, the webhook generates a
  // single-use Stripe promotion code equal to the quiz price ($9.99)
  // that applies to the first Consilium month. Surfaced on the
  // unlocked results page and in the quiz email. 14-day expiry.
  consiliumCreditCode      String?   @unique
  consiliumCreditExpiresAt DateTime?
  // Acquisition attribution — same shape as User. Captured even for
  // anonymous quiz takes so we can join free-tier traffic source
  // against later registration + purchase. Nullable for legacy rows.
  utmSource                String?
  utmMedium                String?
  utmCampaign              String?
  utmContent               String?
  utmTerm                  String?
  gclid                    String?
  fbclid                   String?
  ttclid                   String?
  referrer                 String?
  landingPage              String?
  userAgent                String?
  ipCountry                String?
  language                 String?
  timezone                 String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([primaryType])
  @@index([paypalOrderId])
  @@index([utmSource])
  @@index([utmCampaign])
}

// Newsletter Subscribers
model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  source       String // "newsletter" | "quiz" | "presale" | "book-sample"
  quizResultId String? // Link to quiz if came from quiz
  tags         String[] // For segmentation
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([source])
}

// ========================================
// COMMUNITY FORUM MODELS
// ========================================

enum AccessTier {
  PUBLIC
  REGISTERED
  BOOK_OWNER
  COACHING_CLIENT
  COURSE_SUBSCRIBER
  PREMIUM
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum MemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

// Forum Categories (top-level organization)
model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  icon        String?
  sortOrder   Int         @default(0)
  accessTier  AccessTier  @default(PUBLIC)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  posts       ForumPost[]
  chatRooms   ChatRoom[]

  @@index([slug])
  @@index([accessTier])
}

// Forum Posts (async discussions)
model ForumPost {
  id          String        @id @default(cuid())
  categoryId  String
  authorId    String
  title       String
  slug        String
  content     String        @db.Text
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  viewCount   Int           @default(0)
  likeCount   Int           @default(0)
  replyCount  Int           @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies     ForumReply[]
  likes       PostLike[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@index([lastReplyAt])
}

// Forum Replies (threaded comments)
model ForumReply {
  id        String       @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String       @db.Text
  likeCount Int          @default(0)
  isEdited  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  post      ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    ForumReply?  @relation("ReplyThread", fields: [parentId], references: [id], onDelete: Cascade)
  children  ForumReply[] @relation("ReplyThread")
  likes     ReplyLike[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

// Post Likes
model PostLike {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime  @default(now())
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// Reply Likes
model ReplyLike {
  id        String     @id @default(cuid())
  replyId   String
  userId    String
  createdAt DateTime   @default(now())
  reply     ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@index([replyId])
  @@index([userId])
}

// ========================================
// REAL-TIME CHAT MODELS
// ========================================

model ChatRoom {
  id          String         @id @default(cuid())
  categoryId  String?
  name        String
  slug        String         @unique
  description String?
  accessTier  AccessTier     @default(PUBLIC)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  category    ForumCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]
  members     ChatMember[]

  @@index([slug])
  @@index([accessTier])
}

model ChatMessage {
  id        String      @id @default(cuid())
  roomId    String
  authorId  String
  content   String      @db.Text
  type      MessageType @default(TEXT)
  isEdited  Boolean     @default(false)
  isDeleted Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  room      ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([authorId])
  @@index([createdAt])
}

model ChatMember {
  id       String     @id @default(cuid())
  roomId   String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())
  lastSeen DateTime   @default(now())
  room     ChatRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

// ========================================
// COURSE & SUBSCRIPTION MODELS
// ========================================

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Course {
  id            String             @id @default(cuid())
  title         String
  slug          String             @unique
  description   String?            @db.Text
  thumbnailUrl  String?
  price         Float // Monthly subscription price
  tier          String             @default("standard") // "standard" or "gold"
  isActive      Boolean            @default(true)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  modules       CourseModule[]
  enrollments   CourseEnrollment[]
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
}

model CourseModule {
  id          String         @id @default(cuid())
  courseId    String
  title       String
  slug        String
  description String?        @db.Text
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     CourseLesson[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model CourseLesson {
  id          String           @id @default(cuid())
  moduleId    String
  title       String
  slug        String
  description String?          @db.Text
  videoUrl    String? // Path to video file in /public/CourseVideos/
  duration    Int? // Duration in seconds
  textContent String?          @db.Text
  sortOrder   Int              @default(0)
  isFree      Boolean          @default(false) // Preview lessons
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  module      CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  courseId             String
  paypalSubscriptionId String             @unique
  paypalPlanId         String?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course               Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment           CourseEnrollment?

  @@index([userId])
  @@index([courseId])
  @@index([paypalSubscriptionId])
  @@index([status])
}

model CourseEnrollment {
  id             String           @id @default(cuid())
  courseId       String
  userId         String
  subscriptionId String?          @unique
  status         EnrollmentStatus @default(ACTIVE)
  startedAt      DateTime         @default(now())
  completedAt    DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  progress       LessonProgress[]

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([status])
}

model LessonProgress {
  id             String           @id @default(cuid())
  enrollmentId   String
  lessonId       String
  watchedSeconds Int              @default(0)
  isCompleted    Boolean          @default(false)
  lastWatchedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  enrollment     CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         CourseLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

// ========================================
// ACTIVITY & GAMIFICATION MODELS
// ========================================

// Activity Log - Tracks user actions for activity feed
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String // "purchase" | "session_completed" | "lesson_completed" | "achievement" | "feedback"
  title     String
  metadata  Json? // Flexible data for each activity type
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

// Achievement Definitions
model Achievement {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String
  icon        String // Lucide icon name
  tier        String            @default("bronze") // bronze, silver, gold
  criteria    Json // { type: "sessions_completed", count: 5 }
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@index([slug])
  @@index([tier])
}

// User Achievements - Junction table for earned achievements
model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([earnedAt])
}

// ========================================
// INNER CIRCLE COMMUNITY MODELS
// ========================================

model CommunityMembership {
  id                   String           @id @default(cuid())
  userId               String           @unique
  status               MembershipStatus @default(PENDING)
  paypalSubscriptionId String?          @unique
  billingCycle         String           @default("monthly")
  applicationData      Json?
  appliedAt            DateTime         @default(now())
  approvedAt           DateTime?
  activatedAt          DateTime?
  expiresAt            DateTime?
  cancelledAt          DateTime?
  suspendedAt          DateTime?
  suspendReason        String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([paypalSubscriptionId])
}

model FeedPost {
  id                   String           @id @default(cuid())
  authorId             String?
  title                String
  content              String           @db.Text
  type                 FeedPostType     @default(ANNOUNCEMENT)
  voiceNoteUrl         String?
  videoUrl             String?
  videoPosterUrl       String?
  videoDurationSeconds Int?
  isPinned             Boolean          @default(false)
  isLocked             Boolean          @default(false)
  likeCount            Int              @default(0)
  commentCount         Int              @default(0)
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  author               User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments             FeedComment[]
  likes                FeedPostLike[]
  botActions           BotAction[]      @relation("BotActionsOnPost")
  answersQuestions     MemberQuestion[] @relation("QuestionAnswers")

  @@index([authorId])
  @@index([type])
  @@index([createdAt])
  @@index([isPinned])
}

// Ask Kanika — members submit one question per rolling 24h. Other
// members upvote. Kanika reviews the queue (pre-curated by votes) and
// selects questions to answer in voice notes / videos. When she does,
// the answering FeedPost is linked here, the asker is emailed, and
// their pill nav flips to a green-dot state.
model MemberQuestion {
  id              String           @id @default(cuid())
  userId          String // always stored even when isAnonymous=true; admin can reveal for moderation
  user            User             @relation("MemberQuestions", fields: [userId], references: [id], onDelete: Cascade)
  content         String           @db.Text
  isAnonymous     Boolean          @default(false)
  status          QuestionStatus   @default(PENDING)
  upvoteCount     Int              @default(0) // denormalized so the "top voted" sort is index-cheap
  answeredAt      DateTime?
  answerPostId    String?
  answerPost      FeedPost?        @relation("QuestionAnswers", fields: [answerPostId], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  upvotes         QuestionUpvote[]

  @@index([userId, createdAt])
  @@index([status, upvoteCount(sort: Desc)])
  @@index([status, createdAt])
}

model QuestionUpvote {
  id         String         @id @default(cuid())
  questionId String
  question   MemberQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation("QuestionUpvotes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([questionId, userId])
  @@index([userId])
}

// Singleton settings row. Lets Kanika change the daily cap (and other
// limits) without a code change. Mirrors the BotEngagementSettings pattern.
model MemberQuestionSettings {
  id        String   @id @default("singleton")
  dailyCap  Int      @default(1)
  maxLength Int      @default(500)
  updatedAt DateTime @updatedAt
}

enum QuestionStatus {
  PENDING // in queue, awaiting Kanika's review
  ANSWERING // marked by admin, voice/video being prepared
  ANSWERED // has answerPostId
  REJECTED // not appropriate / off-topic
  HIDDEN // hidden from public list (spam / abuse)
}

model FeedComment {
  id        String          @id @default(cuid())
  postId    String
  authorId  String
  content   String          @db.Text
  status    CommentStatus   @default(PENDING_REVIEW)
  parentId  String?
  likeCount Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  post      FeedPost        @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    FeedComment?    @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  children  FeedComment[]   @relation("CommentThread")
  likes     CommentLike[]
  reports   CommentReport[]

  @@index([postId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
}

model FeedPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommentLike {
  id        String      @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime    @default(now())
  comment   FeedComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

// ========================================
// EMAIL AUTOMATION
// ========================================

model EmailQueue {
  id             String    @id @default(cuid())
  recipientEmail String
  recipientName  String
  sequence       String // "book-buyer-welcome", "trial-reminder", etc.
  step           Int // 1, 2, 3...
  subject        String
  htmlBody       String    @db.Text
  scheduledAt    DateTime
  sentAt         DateTime?
  status         String    @default("PENDING") // PENDING, SENT, FAILED, CANCELLED
  metadata       Json? // trial tokens, context
  createdAt      DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([recipientEmail])
  @@index([sequence])
}

// ========================================
// AUTOMATED CONTENT SEEDING
// ========================================

model DailyInsight {
  id              String    @id @default(cuid())
  content         String    @db.Text
  category        String // "manipulation-tactic", "defense-strategy", "relationship-pattern", "power-dynamic", "psychology-concept"
  personalityType String? // null = universal, or "predator", "wildcard", "emperor", "storm", "siren", "balanced"
  dayOfYear       Int // 1-366, for scheduling
  isUsed          Boolean   @default(false)
  postedAt        DateTime?
  createdAt       DateTime  @default(now())

  @@index([dayOfYear])
  @@index([category])
  @@index([personalityType])
}

/// Sliding-window rate limit counters.
///
/// Each row is a "bucket" identified by a composite key of the action being
/// limited (e.g. "auth:login") and the subject (IP address, userId, or
/// email). The `windowStart` is the start of the current window; `count` is
/// how many requests have been made in that window.
///
/// The helper in lib/rate-limit.ts handles read-modify-write atomically via
/// prisma.$transaction + an upsert. A cleanup cron should periodically
/// delete rows older than their window — not critical since stale rows are
/// just harmless clutter, but nice to have.
model RateLimit {
  id          String   @id @default(cuid())
  /// Namespace + action being limited, e.g. "auth:login" or "feed:comment"
  action      String
  /// Subject being limited: IP, userId, or email depending on the action
  subject     String
  /// Current count within the window
  count       Int      @default(0)
  /// When the current window started (UTC)
  windowStart DateTime @default(now())
  /// Last update, for GC
  updatedAt   DateTime @updatedAt

  @@unique([action, subject])
  @@index([windowStart])
}

model DiscussionPrompt {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  dayOfWeek Int // 0=Sunday, 1=Monday ... 6=Saturday
  theme     String // "manipulation-monday", "toxic-tuesday", etc.
  variation Int // 1-4, for rotating weekly
  isUsed    Boolean   @default(false)
  postedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([dayOfWeek])
  @@index([theme])
  @@index([isUsed])
}

// ── Content Dashboard ──

enum ContentIdeaStatus {
  PENDING
  APPROVED
  REJECTED
}

model ContentIdea {
  id        String            @id @default(cuid())
  title     String
  hook      String?           @db.Text
  format    String?
  source    String
  category  String?
  status    ContentIdeaStatus @default(PENDING)
  notes     String?           @db.Text
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Pipeline development fields. UI on /admin/content "Develop" tab walks
  // an APPROVED idea through hook → line2 → line3, with the framework's
  // recommended L2/L3 mechanisms surfaced based on the chosen hookType.
  // See docs/content-research/lines-2-3-framework.md.
  line2            String? @db.Text
  line3            String? @db.Text
  // FIRST_PERSON_MECHANISM | DIAGNOSTIC_CORRECTION | INTERIOR_MONOLOGUE | METHOD_EXPOSURE
  hookType         String?
  // INVALIDATE | SPECIFICITY_ESCALATION | PERSONAL_STAKE | REFRAME
  line2Mechanism   String?
  // SPECIFIC_MECHANISM | DIAGNOSTIC | PROTECTIVE_INVERSION | CONTINUATION
  line3Mechanism   String?
  // PROTECTIVE | PREDATORY | NEUTRAL — algorithm + shareability signal
  frame            String?
  // CONCEPT | HOOK_DRAFTED | LINES_DRAFTED | READY_TO_FILM | FILMED | PUBLISHED
  developmentStage String  @default("CONCEPT")

  // Full 60-second architecture beats (see middle-end-architecture.md).
  // 8-15s — orient the viewer to the framework
  setup              String? @db.Text
  // 30-45s — the deepening beat
  deepening          String? @db.Text
  // SECOND_EXAMPLE | OBJECTION_HANDLE | PERSONAL_DISCLOSURE | ESCALATION
  deepeningMechanism String?
  // 45-55s — the close beat (distinct from prior "line3 closes the loop")
  closeBeat          String? @db.Text
  // FRAMEWORK_SUMMARY (saves) | PROTECTIVE_HANDOFF (shares) | DIAGNOSTIC_QUESTION (comments) | IMPLIED_CATALOGUE (follows)
  closeMechanism     String?
  // 55-60s — optional rewatch trigger
  tail               String? @db.Text
  // LONG (45-60s) | SHORT (15-25s) — different optimization for each
  videoFormat        String  @default("LONG")

  // Optional link to a shock-and-awe confession line drawn from the bank.
  // When set, the API bumps usedCount + stamps lastUsedAt on the confession
  // so we don't burn the same legendary line twice in 6 months.
  confessionId String?
  confession   ContentConfession? @relation(fields: [confessionId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([source])
  @@index([developmentStage])
  @@index([confessionId])
}

// Shock-and-awe confession bank. See docs/content-research/shock-and-awe-framework.md.
// Each row is a single confession line. Categories grouped in UI.
// Pull from this bank when scripting videos — don't generate on-the-fly.
model ContentConfession {
  id         String    @id @default(cuid())
  // LYING_WITHOUT_GUILT | CALCULATED_KINDNESS | EXPLOITING_VULNERABILITY |
  // INDIFFERENCE_TO_HARM | PERFORMING_EMOTIONS | FINDING_VULNERABILITY_BORING |
  // MIMICKING_GRIEF_OR_LOVE | MANIPULATING_LOVED_ONES |
  // TREATING_RELATIONSHIPS_AS_SYSTEMS | NOT_FEELING_EXPECTED_THINGS | (custom)
  category   String
  // The actual confession line, in its rawest form (softening stripped).
  text       String    @db.Text
  // STANDARD | STRONG | LEGENDARY — quality tier.
  // Aim for ~1 LEGENDARY per 5 lines. 3-4 LEGENDARY per 20 videos shipped.
  tier       String    @default("STANDARD")
  // HOOK | TAIL | DEEPENING — where this line plays best.
  placement  String?
  // Set when shipped in a video (manual or via future ContentIdea linkage).
  // Don't burn the same legendary line twice in 6 months.
  usedCount  Int       @default(0)
  lastUsedAt DateTime?
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ideas ContentIdea[]

  @@index([category])
  @@index([tier])
}

model ResearchNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  source    String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoAnalysis {
  id         String   @id @default(cuid())
  url        String
  title      String?
  platform   String   @default("youtube")
  transcript String?  @db.Text
  analysis   Json?
  createdAt  DateTime @default(now())

  @@index([platform])
}

// Member-filed reports on feed comments. Each (commentId, reporterId)
// is unique so a member can't spam the report button. When admin
// "resolves" a report (approves the comment as fine, or hides it,
// or restricts the author), resolvedAt + resolvedById are set.
model CommentReport {
  id           String      @id @default(cuid())
  commentId    String
  reporterId   String
  reason       String?
  createdAt    DateTime    @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  comment      FeedComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter     User        @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver     User?       @relation("ReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([commentId, reporterId])
  @@index([commentId])
  @@index([reporterId])
  @@index([resolvedAt])
}

// Per-user, per-scenario progress for the Dark Mirror simulator game.
// One row per (userId, scenarioId). Replaying overwrites the row — we
// keep only the most recent playthrough per scenario, so `completedAt`
// and `outcome` reflect the latest run. If we later want a full history
// for replay analytics, add a separate SimulatorRun table that this one
// summarizes.
model SimulatorProgress {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId      String
  currentSceneId  String
  // Full ordered list of choices as a JSON array of
  // { sceneId, choiceId, wasOptimal, timestamp }. Cheaper than a
  // join-table and we never query across users' choice history.
  choicesMade     Json      @default("[]")
  xpEarned        Int       @default(0)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  // "good" | "neutral" | "bad" — null until an ending is reached.
  outcome         String?
  // Incremented by /api/simulator/complete every time a run reaches
  // an ending, including replays. Used by the `three-time-reader`
  // meta-achievement in `lib/simulator/achievements.ts`. Stays 0 for
  // in-progress rows; ticks to 1 on first completion, 2 on second, etc.
  completionCount Int       @default(0)
  // Distinct ending sceneIds the user has reached on this scenario across
  // all their replays. Length vs scenes.filter(isEnding).length renders
  // the "X / Y endings found" counter on catalog cards. Each replay adds
  // its endSceneId only if it isn't already in the array — so it's a set,
  // not a log. Empty until first completion.
  endingsReached  String[]  @default([])

  @@unique([userId, scenarioId])
  @@index([userId])
  @@index([scenarioId])
}

// Badges awarded on scenario completion, level mastery, or secret
// objectives. `badgeKey` is the stable slug (e.g. "mission-1-1-good",
// "level-1-mastery", "pattern-recognition"). Uniqueness means a user
// can't double-earn the same badge, even across replays.
model SimulatorBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
}

// ========================================
// BOT ENGAGEMENT MODELS
// ========================================

enum BotActionType {
  COMMENT
  LIKE
}

enum BotActionStatus {
  PENDING
  EXECUTED
  FAILED
  SKIPPED
}

// Scheduled bot actions queued by the engagement engine.
// Each row represents one bot doing one thing (comment or like)
// on one FeedPost at a specific time. The bot is a real User row
// with isBot = true. Processed by /api/cron/bot-engagement.
model BotAction {
  id            String          @id @default(cuid())
  type          BotActionType
  status        BotActionStatus @default(PENDING)
  bot           User            @relation(fields: [botId], references: [id], onDelete: Cascade)
  botId         String
  post          FeedPost        @relation("BotActionsOnPost", fields: [postId], references: [id], onDelete: Cascade)
  postId        String
  scheduledAt   DateTime
  executedAt    DateTime?
  commentText   String?         @db.Text
  commentId     String?
  failureReason String?
  attempts      Int             @default(0)
  createdAt     DateTime        @default(now())

  @@index([status, scheduledAt])
  @@index([postId])
  @@index([botId])
}

// Singleton settings row for the bot engagement engine.
// Always queried with findUnique({ where: { id: "singleton" } }).
// dryRun = true means actions are logged but not written to DB.
model BotEngagementSettings {
  id        String   @id @default("singleton")
  enabled   Boolean  @default(false)
  dryRun    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Web Push subscription per device. A user can have multiple
// (phone + tablet + laptop). Stored as the literal PushSubscription
// JSON the browser hands back, plus a few derived fields for
// admin-side filtering and pruning. The server uses these endpoints
// to deliver notifications via VAPID.
//
// Endpoints occasionally expire / get revoked (user reset Chrome,
// uninstalled the PWA, etc). When web-push returns 404/410 for a
// subscription, we delete the row in the helper. No cron needed.
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The browser-issued push endpoint. UNIQUE — same browser/device
  // always returns the same endpoint, so an upsert keeps re-subscribes
  // idempotent without duplicate rows.
  endpoint String @unique
  p256dh   String // public key for ECDH key agreement
  auth     String // shared auth secret

  // User-agent at subscription time, useful for "your iPhone, your
  // Pixel" labels in member prefs UI later. Not used for delivery.
  userAgent String?

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// TELLS — daily Train-Your-Instincts exercises
// ============================================================================

// One Tell is a single 45-90 second exercise: an artifact (voicemail, text
// exchange, paragraph) plus a multiple-choice question plus a Kanika-voice
// reveal. Tells are scheduled to publish on a given date; the public /tells
// surface picks PUBLISHED Tells whose scheduleDate <= now, ordered by
// scheduleDate desc, deduped to one-per-day for the daily wedge.
model Tell {
  id           String        @id @default(cuid())
  // Public-facing index, e.g. "Tell 247". Auto-incremented at create time
  // by the API route, NOT a sequence — we want gaps to be impossible
  // even if a Tell is later archived. Display only, never used for routing.
  number       Int           @unique
  // Slug for /tells/[slug] deep links. URL-safe, derived from question
  // or set manually in the admin UI.
  slug         String        @unique
  format       TellFormat
  track        InstinctTrack
  // Multi-axis tagging via parallel array of strings. Postgres handles
  // the array natively; an enum array would be tidier but Prisma's
  // enum-array support is fragile across migrations.
  axes         String[] // InstinctAxis values
  difficulty   Int           @default(3) // 1-5
  // Polymorphic artifact payload. Shape depends on format:
  //   voicemail     → { kind, speakerLabel, transcript, durationLabel? }
  //   text-exchange → { kind, label?, lines: [{from, text}] }
  //   paragraph     → { kind, label?, text }
  //   scene         → { kind, label?, text }
  artifact     Json
  question     String
  // Choices array: [{ id, text, isCorrect, why }]. Exactly 4 entries,
  // exactly 1 with isCorrect=true. Validated at API layer.
  choices      Json
  // Kanika-voice teach, 60-100 words. Read after the choice locks.
  reveal       String        @db.Text
  // The day this Tell becomes "Today's Tell" on /tells. Null = not
  // scheduled yet (status DRAFT/REVIEW). UTC date-only is the conceptual
  // type but we store DateTime for Prisma indexing.
  scheduleDate DateTime?
  status       TellStatus    @default(DRAFT)
  authorId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses TellResponse[]

  @@index([scheduleDate, status])
  @@index([track, status])
  @@index([status])
}

enum TellFormat {
  DIAGNOSE
  SPOT_THE_MOVE
  NEXT_OPTIMAL
  FIND_THE_DECOY
  GRADE_THE_REPLY
}

enum InstinctTrack {
  DARK_PSYCH
  RED_FLAGS
  CROSS_SEX
  POWER
  REFUSAL
  SELF_REG
}

enum TellStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

// Every answer submission writes one TellResponse row. For logged-in
// users a partial unique index (added in the migration SQL, since
// Prisma cannot express "unique where userId IS NOT NULL") prevents
// the same user counting a Tell toward score twice. Anonymous responses
// can repeat freely — they are the visit telemetry.
model TellResponse {
  id            String   @id @default(cuid())
  userId        String?
  // Cookie-issued anonymous id for visit-level deduping when userId is null.
  anonId        String?
  tellId        String
  // Which choice id from the Tell.choices array they picked.
  choiceId      String
  isCorrect     Boolean
  // Net Elo delta from this answer. 0 for replays and bonus-overflow.
  scoreImpact   Int      @default(0)
  // Per-axis Elo delta as a JSON object, e.g. { "READ": 12, "SPOT": 4 }.
  // Empty object for replays.
  axesImpact    Json
  // Whether this response counted toward score (one main per UTC day,
  // up to two bonus per day, replays do not count). Computed at write,
  // stored to avoid re-deriving on retention queries.
  countedScored Boolean  @default(true)
  // Whether this response counted toward streak (only the main).
  countedStreak Boolean  @default(false)
  answeredAt    DateTime @default(now())
  // Time-to-answer in milliseconds, for difficulty calibration.
  answerMs      Int?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  tell Tell  @relation(fields: [tellId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt])
  @@index([anonId])
  @@index([tellId])
}

// Six-axis Elo rating per user. One row per user, created lazily on
// first scored response. Default 1000 across all axes (mid-tier baseline).
model InstinctScore {
  id            String   @id @default(cuid())
  userId        String   @unique
  read          Int      @default(1000)
  spot          Int      @default(1000)
  reply         Int      @default(1000)
  refuse        Int      @default(1000)
  calibrate     Int      @default(1000)
  hold          Int      @default(1000)
  // Total scored responses (main + bonus). Used for K-factor decay
  // (K=24 for the first 30, K=16 thereafter).
  totalAnswered Int      @default(0)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Per-user streak with one auto-applied freeze per ISO week. Created
// lazily on first main-Tell completion. UTC day boundaries.
model TellStreak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentDays   Int      @default(0)
  longestDays   Int      @default(0)
  // YYYY-MM-DD UTC of the last main-Tell completion.
  lastTellDate  String?
  // ISO week key (YYYY-Wnn) tracking when the freeze last reset.
  freezeWeekKey String?
  // 1 if a freeze is available this week, 0 if used.
  freezesAvail  Int      @default(1)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// RECEIPTS — premium AI text-reader, "paste your situation, get the read"
// ============================================================================

// One Receipt per Kanika-voice read of a user-supplied text exchange.
//
// Privacy posture: we DO NOT store the raw input. We store:
//   - the response Kanika returned (so the user can revisit later)
//   - an inputCharCount for cost analytics
//   - a sha256 hash of the input for replay-detection only
// If a future product decision needs the input persisted (e.g. a true
// "history view"), add an inputText field then; do not add it lazily
// because it raises the bar on backups + GDPR + threat model.
model Receipt {
  id             String   @id @default(cuid())
  userId         String
  // User-provided label for their own organisation, e.g. "ex Tuesday".
  // Optional, defaults to "Untitled" on display.
  label          String?
  // Kanika-voice response, the read.
  response       String   @db.Text
  // Length of the input the user pasted, in characters, for cost
  // analytics and to detect "the user pasted a novel" abuse.
  inputCharCount Int
  // sha256 hex of the input. Used only to detect a same-input replay
  // (return the same response without re-billing the LLM).
  inputHash      String
  // Model ID actually called, so cost analytics can split by model.
  model          String
  // Cost in USD * 10000, rounded. Stored as int to avoid float weirdness.
  costMicros     Int      @default(0)

  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([inputHash])
}
