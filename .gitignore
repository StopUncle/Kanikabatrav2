# Private files (books, sensitive content)
/private/*
!/private/books/
/private/books/*.txt
/private/books/*.md
# The download route reads specific canonical filenames:
# FINAL_BOOK.{epub,pdf} and Addendum_{Narcissists,Avoidants}.{epub,pdf}.
# Fresh Calibre exports dumped into subdirectories or with different
# filenames are dead weight — keep them out of the repo.
/private/books/EVENBETTERBOOK/
/private/books/Addendums/
/private/books/book-cover.*
/private/books/*-stylesheet.css

# Local cleanup scripts and their logs
.cleanup-log.txt
.cleanup.ps1

# Claude Code internal state (lockfiles, per-session temp)
.claude/

# Environment files
.env
.env.local
.env.production
env.json

# Dev mode config (don't commit dev buttons)
lib/dev-mode.ts

# Prevent document.tsx in app directory (App Router incompatible)
app/document.tsx
app/_document.tsx

